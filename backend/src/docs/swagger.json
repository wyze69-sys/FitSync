{
  "openapi": "3.0.0",
  "info": {
    "title": "FitSync AI API Documentation 🏋️‍♂️✨",
    "description": "Full REST API Swagger / Postman catalog mapping all endpoints, security controllers, administrative channels, and Google Gemini AI insights services.",
    "version": "1.0.0",
    "contact": {
      "name": "FitSync AI University Cross-Disciplinary Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Development Server"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register a new regular Athlete or Admin account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {"type": "string", "example": "athlete@fitsync.com"},
                  "password": {"type": "string", "example": "fitness123"},
                  "name": {"type": "string", "example": "Sarah Coleman"},
                  "role": {"type": "string", "enum": ["user", "admin"], "example": "user"}
                },
                "required": ["email", "password", "name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Athlete registered successfully and session token created."
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Authenticate credentials to generate safe JWT keys",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {"type": "string", "example": "user@fitsync.com"},
                  "password": {"type": "string", "example": "fitness123"}
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication return token."
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Retrieve session metadata of currently connected profile",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "Returns safe verified user profile schema."
          }
        }
      }
    },
    "/workouts": {
      "get": {
        "summary": "Query historical list of workouts recorded under session user",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "List of workouts complete with nested exercise sets."
          }
        }
      },
      "post": {
        "summary": "Record a completed custom workout session",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": {"type": "string", "example": "2026-05-27"},
                  "title": {"type": "string", "example": "Lower Body Squat Prep"},
                  "notes": {"type": "string", "example": "Felt good, slight knee soreness"},
                  "exercises": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "categoryId": {"type": "string", "example": "cat_2"},
                        "categoryName": {"type": "string", "example": "Strength & Core"},
                        "exerciseName": {"type": "string", "example": "Barbell Squats"},
                        "duration": {"type": "integer", "example": 30},
                        "caloriesBurned": {"type": "integer", "example": 210},
                        "sets": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "reps": {"type": "integer", "example": 8},
                              "weight": {"type": "number", "example": 60.0}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout database logs persisted successfully."
          }
        }
      }
    },
    "/ai/generate-weekly-insight": {
      "post": {
        "summary": "Securely forward metrics to Gemini Pro to generate training advice",
        "security": [{"BearerAuth": []}],
        "responses": {
          "201": {
            "description": "Returns synthesized coach summary, action items list, and goal evaluation."
          }
        }
      }
    },
    "/admin/stats": {
      "get": {
        "summary": "Get aggregate analytics across entire MySQL database rows (Admin Only)",
        "security": [{"BearerAuth": []}, {"AdminRole": []}],
        "responses": {
          "200": {
            "description": "Returns users counts, total track runs counts, category distributions."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
